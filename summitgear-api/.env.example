# SummitGear API — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# Ne jamais committer le fichier .env

# Serveur
PORT=3001
NODE_ENV=development

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me
DB_NAME=summitgear

# URL complète pour Prisma
DATABASE_URL=postgresql://postgres:change_me@localhost:5432/summitgear

# Authentification JWT
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# CORS — origine autorisée (frontend)
CORS_ORIGIN=http://localhost:5173