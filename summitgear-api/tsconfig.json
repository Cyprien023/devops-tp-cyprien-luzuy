{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "jest"]
  },
  "include": [
    "src/**/*",
    "node_modules/@types/jest/index.d.ts",
    "node_modules/@types/jest/index.d.ts",
    "node_modules/@types/jest/index.d.ts"
  ],
  "exclude": ["node_modules"]
}